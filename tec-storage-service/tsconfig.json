{
  "compilerOptions": {
    "module":                 "CommonJS",
    "moduleResolution":       "Node",
    "target":                 "ES2020",
    "lib":                    ["ES2020"],
    "outDir":                 "dist",
    "rootDir":                "src",
    "strict":                 true,
    "esModuleInterop":        true,
    "skipLibCheck":           true,
    "declaration":            true,
    "emitDecoratorMetadata":  true,
    "experimentalDecorators": true,
    "resolveJsonModule":      true,
    "types":                  ["jest", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
