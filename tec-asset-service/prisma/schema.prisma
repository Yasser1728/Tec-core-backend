generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetCategory {
  DOMAIN
  REAL_ESTATE
  DIGITAL_ASSET
}

enum AssetStatus {
  ACTIVE
  PENDING
  LOCKED
  ON_SALE
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

model Asset {
  id            String        @id @default(uuid())
  transactionId String        @unique
  ownerId       String
  slug          String        @unique
  category      AssetCategory
  status        AssetStatus   @default(ACTIVE)
  metadata      Json
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  history  AssetHistory[]
  listings AssetListing[]

  @@index([ownerId])
}

model AssetHistory {
  id            String   @id @default(uuid())
  assetId       String
  toOwnerId     String
  transactionId String
  createdAt     DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([toOwnerId])
}

model AssetListing {
  id          String        @id @default(uuid())
  assetId     String
  sellerId    String
  price       Float
  currency    String        @default("PI")
  status      ListingStatus @default(ACTIVE)
  title       String?
  description String?
  paymentId   String?       @unique
  buyerId     String?
  soldAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([assetId])
  @@map("asset_listings")
}
