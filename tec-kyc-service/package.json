{
  "name": "tec-kyc-service",
  "version": "1.0.0",
  "description": "TEC KYC Service — Identity Verification",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.39.0",
    "fastify": "^4.0.0",
    "ioredis": "^5.9.3",
    "pino": "^9.0.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.19.33",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.spec.ts"],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "kyc.service.spec.ts"
    ],
    "testTimeout": 10000,
    "forceExit": true,
    "moduleNameMapper": {
      "^../prisma/prisma.service$": "<rootDir>/src/__tests__/__mocks__/prisma.mock.ts"
    }
  }
}
