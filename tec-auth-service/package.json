{
  "name": "tec-auth-service",
  "version": "2.0.0",
  "scripts": {
    "build":         "prisma generate && nest build",
    "start":         "node dist/main",
    "start:dev":     "nest start --watch",
    "start:prod":    "node dist/main",
    "test":          "jest",
    "test:watch":    "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common":           "^10.0.0",
    "@nestjs/core":             "^10.0.0",
    "@nestjs/jwt":              "^10.0.0",
    "@nestjs/config":           "^3.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler":        "^5.0.0",
    "@prisma/client":           "^5.22.0",
    "axios":                    "^1.6.0",
    "bcrypt":                   "^5.1.1",
    "class-validator":          "^0.14.0",
    "class-transformer":        "^0.5.1",
    "express":                  "^4.18.0",
    "helmet":                   "^7.0.0",
    "ioredis":                  "^5.9.3",
    "reflect-metadata":         "^0.1.13",
    "rxjs":                     "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli":        "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing":    "^10.0.0",
    "@types/axios":       "^0.14.0",
    "@types/bcrypt":      "^5.0.2",
    "@types/express":     "^4.17.17",
    "@types/jest":        "^29.0.0",
    "@types/node":        "^20.0.0",
    "@types/supertest":   "^6.0.0",
    "jest":               "^29.0.0",
    "prisma":             "^5.22.0",
    "supertest":          "^7.0.0",
    "ts-jest":            "^29.0.0",
    "typescript":         "^5.0.0"
  },
  "jest": {
    "preset":          "ts-jest",
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.spec.ts", "**/__tests__/**/*.test.ts"],
    "testTimeout":     10000,
    "forceExit":       true,
    "moduleNameMapper": {
      "^../../prisma/client$": "<rootDir>/__tests__/__mocks__/prisma.ts"
    }
  }
}
