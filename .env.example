# TEC Platform - Global Environment Variables
# Copy this file to .env and fill in the values

# --- API Gateway ---
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,https://tec-app.vercel.app

# --- Internal Service URLs (For Gateway to route traffic) ---
AUTH_SERVICE_URL=http://tec-auth-service:8080
WALLET_SERVICE_URL=http://tec-wallet-service:8080
PAYMENT_SERVICE_URL=http://tec-payment-service:8080

# --- Databases ---
POSTGRES_USER=tec_admin
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=tec_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

REDIS_URL=redis://redis:6379

# --- Security ---
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=1h

# --- Pi Network Configuration ---
PI_NETWORK_ENV=testnet # Use 'mainnet' for production

# Pi Testnet Keys
PI_API_KEY_TESTNET=your_testnet_api_key_here
PI_WALLET_TESTNET=your_testnet_wallet_address_here

# Pi Mainnet Keys
PI_API_KEY_MAINNET=your_mainnet_api_key_here
PI_WALLET_MAINNET=your_mainnet_wallet_address_here