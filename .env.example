# TEC Platform - Global Environment Variables
# Copy this file to .env and fill in the values

# --- API Gateway ---
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,https://tec-app.vercel.app

# --- Internal Service URLs (For Gateway to route traffic) ---
AUTH_SERVICE_URL=http://tec-auth-service:8080
WALLET_SERVICE_URL=http://tec-wallet-service:8080
PAYMENT_SERVICE_URL=http://tec-payment-service:8080

# --- Databases ---
POSTGRES_USER=tec_admin
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=tec_db
DATABASE_URL=postgresql://tec_admin:secure_password@postgres:5432/tec_db?schema=public

REDIS_URL=redis://redis:6379

# --- Security ---
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=1h

# Optional secret used by the API gateway to sign/verify the x-internal-key header for internal service-to-service calls
INTERNAL_SECRET=your_internal_secret_here

# --- Pi Network Configuration ---
# Set to 'true' to use Pi Sandbox/Testnet, 'false' to use Mainnet
PI_SANDBOX=true

# Pi API credentials
PI_API_KEY=your_pi_api_key_here
PI_APP_ID=your_pi_app_id_here
