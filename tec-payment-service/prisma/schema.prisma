// tec-payment-service/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id             String            @id @default(uuid())
  user_id        String
  amount         Float
  currency       String            @default("PI")
  payment_method String
  status         String            @default("created")
  pi_payment_id  String?           @unique
  transaction_id String?
  metadata       Json?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  approved_at    DateTime?
  completed_at   DateTime?
  failed_at      DateTime?
  cancelled_at   DateTime?
  deleted_at     DateTime?
  auditLogs      PaymentAuditLog[]

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("payments")
}

enum AuditEventType {
  PAYMENT_INITIATED
  PAYMENT_APPROVED
  PAYMENT_CONFIRMED
  PAYMENT_CANCELLED
  PAYMENT_FAILED
  INVALID_TRANSITION_ATTEMPT
  PAYMENT_WEBHOOK_RECEIVED
  PAYMENT_RECONCILED
}

model PaymentAuditLog {
  id        String         @id @default(uuid())
  userId    String
  paymentId String?
  payment   Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  eventType AuditEventType
  metadata  Json?
  ipAddress String?
  requestId String?
  timestamp DateTime       @default(now())

  @@index([userId])
  @@index([paymentId])
  @@index([timestamp])
  @@map("payment_audit_logs")
}

// ✅ Outbox Pattern — ضمان delivery للـ events
model OutboxEvent {
  id           String    @id @default(uuid())
  stream_name  String                        // اسم الـ Redis stream
  payload      Json                          // الـ event data
  status       String    @default("pending") // pending | published | failed
  attempts     Int       @default(0)         // عدد المحاولات
  max_attempts Int       @default(5)         // أقصى عدد محاولات
  error        String?                       // آخر error
  created_at   DateTime  @default(now())
  published_at DateTime?                     // وقت النشر الناجح
  next_retry   DateTime  @default(now())     // وقت المحاولة الجاية

  @@index([status])
  @@index([next_retry])
  @@index([created_at])
  @@map("outbox_events")
}
