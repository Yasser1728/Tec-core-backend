{
  "name": "tec-payment-service",
  "version": "1.0.0",
  "description": "TEC Payment Service — Pi Network payment processing",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev":   "ts-node src/server.ts",
    "lint":  "eslint \"src/**/*.ts\"",
    "test":  "jest --forceExit"
  },
  "dependencies": {
    "@prisma/client":         "^5.22.0",
    "@sentry/node":           "^8.0.0",
    "@yasser172/tec-shared":  "^1.0.0",
    "cors":                   "^2.8.5",
    "dotenv":                 "^16.0.0",
    "express":                "^4.18.0",
    "express-rate-limit":     "^7.0.0",
    "express-validator":      "^7.0.0",
    "helmet":                 "^7.0.0",
    "ioredis":                "^5.3.0",
    "jsonwebtoken":           "^9.0.3",
    "node-cron":              "^3.0.0",
    "pino":                   "^9.0.0",
    "prom-client":            "^15.0.0",
    "uuid":                   "^9.0.0",
    "zod":                    "^3.0.0"
  },
  "devDependencies": {
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jest":         "^29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node":         "^20.0.0",
    "@types/node-cron":    "^3.0.0",
    "@types/supertest":    "^6.0.0",
    "@types/uuid":         "^9.0.0",
    "jest":                "^29.0.0",
    "prisma":              "^5.22.0",
    "supertest":           "^7.0.0",
    "ts-jest":             "^29.0.0",
    "typescript":          "^5.0.0"
  },
  "jest": {
    "preset":          "ts-jest",
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.ts", "**/__tests__/**/*.spec.ts", "src/__tests__/**/*.test.ts"],
    "testTimeout":     10000,
    "forceExit":       true,
    "setupFiles":      ["./jest.setup.ts"]
  }
}
