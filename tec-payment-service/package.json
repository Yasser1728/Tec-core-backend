{
  "name": "tec-payment-service",
  "version": "1.0.0",
  "description": "TEC Platform Payment Service - Multi-method payment processing",
  "main": "dist/server.js",
  "scripts": {
    "postinstall":   "prisma generate",
    "dev":           "tsx watch src/server.ts",
    "build":         "prisma generate && tsc",
    "start":         "node dist/server.js",
    "lint":          "eslint \"src/**/*.ts\"",
    "test":          "jest",
    "test:watch":    "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@tec/shared":        "file:../shared",
    "@prisma/client":     "^5.22.0",
    "@sentry/node":       "^10.39.0",
    "cors":               "^2.8.6",
    "dotenv":             "^16.6.1",
    "express":            "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-validator":  "^7.0.1",
    "helmet":             "^7.2.0",
    "ioredis":            "^5.9.3",
    "jsonwebtoken":       "^9.0.3",
    "node-cron":          "^3.0.3",
    "pino":               "^10.3.1",
    "pino-http":          "^11.0.0",
    "prom-client":        "^15.1.3",
    "prisma":             "^5.22.0",
    "uuid":               "^9.0.1",
    "zod":                "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js":            "^9.0.0",
    "@types/cors":           "^2.8.19",
    "@types/express":        "^4.17.25",
    "@types/jest":           "^30.0.0",
    "@types/jsonwebtoken":   "^9.0.10",
    "@types/node":           "^20.19.33",
    "@types/node-cron":      "^3.0.11",
    "@types/supertest":      "^6.0.3",
    "@types/uuid":           "^9.0.8",
    "eslint":                "^9.0.0",
    "globals":               "^15.0.0",
    "jest":                  "^30.0.0",
    "supertest":             "^7.2.2",
    "ts-jest":               "^29.1.1",
    "tsx":                   "^4.0.0",
    "typescript":            "^5.9.3",
    "typescript-eslint":     "^8.0.0"
  },
  "overrides": {
    "glob":         "^13.0.0",
    "test-exclude": "^7.0.0"
  },
  "jest": {
    "preset":          "ts-jest",
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.ts"],
    "testPathIgnorePatterns": [
      "__tests__/integration/middleware.test.ts"
    ],
    "setupFiles":      ["./__tests__/setup.ts"],
    "testTimeout":     10000,
    "forceExit":       true,
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/config/**",
      "!src/infra/**",
      "!src/server.ts",
      "!src/utils/logger.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches":   58,
        "functions":  68,
        "lines":      72,
        "statements": 72
      }
    },
    "coverageReporters": ["text", "lcov", "json-summary"]
  }
}
